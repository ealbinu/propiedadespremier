---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;

const faqs = [
  {
    pregunta: '¿Qué es Propiedades Premier?',
    respuesta: 'Propiedades Premier es una plataforma de gestión inmobiliaria para México. Te permite registrar tus propiedades, llevar el control de pagos de predial, luz, agua y otros servicios, y recibir alertas antes de las fechas de vencimiento.',
  },
  {
    pregunta: '¿Cuánto cuesta usar la plataforma?',
    respuesta: 'El acceso básico es completamente gratuito. Puedes registrar tus propiedades y gestionar todos tus pagos sin costo.',
  },
  {
    pregunta: '¿Qué tipos de pagos puedo registrar?',
    respuesta: 'Puedes registrar cualquier tipo de pago vinculado a tus propiedades: predial, servicio de luz (CFE), agua (SACMEX, SIAPA, etc.), mantenimiento, cuotas de condominio, seguros, y cualquier otro concepto personalizado.',
  },
  {
    pregunta: '¿Qué es una línea de captura?',
    respuesta: 'La línea de captura es un código de referencia que emiten las autoridades o instituciones para que puedas pagar en bancos, tiendas de conveniencia o en línea. Propiedades Premier te permite almacenar y consultar las líneas de captura de cada uno de tus pagos de forma organizada.',
  },
  {
    pregunta: '¿Cómo funcionan las alertas de vencimiento?',
    respuesta: 'Desde la sección "Alertas" en tu dashboard puedes ver todos tus pagos próximos a vencer ordenados por urgencia. Los pagos que vencen en menos de 3 días se marcan en rojo, y los que vencen en menos de 15 días en amarillo, para que nunca pierdas una fecha límite.',
  },
  {
    pregunta: '¿Puedo registrar varias propiedades?',
    respuesta: 'Sí, puedes registrar todas las propiedades que necesites: casas, departamentos, terrenos, locales comerciales, oficinas, bodegas y más. No hay límite de propiedades.',
  },
  {
    pregunta: '¿Mis datos están seguros?',
    respuesta: 'Sí. Toda la información se almacena de forma segura en PocketBase con autenticación por token. Tu sesión está protegida con cookies HttpOnly y cada usuario solo puede ver y modificar sus propios datos.',
  },
  {
    pregunta: '¿Cómo puedo marcar un pago como realizado?',
    respuesta: 'Desde la sección "Pagos" de tu dashboard, cada pago pendiente tiene un botón "PAGADO". Al presionarlo, se registra la fecha de pago y el estatus cambia automáticamente.',
  },
  {
    pregunta: '¿Puedo usar la plataforma desde mi celular?',
    respuesta: 'Sí, la plataforma está diseñada de manera responsiva y funciona perfectamente en celulares. Además, en móvil encontrarás una barra de navegación inferior para acceder rápidamente a todas las secciones.',
  },
  {
    pregunta: '¿Cómo contacto al soporte?',
    respuesta: 'Puedes escribirnos directamente a hola@propiedadespremier.com y te responderemos a la brevedad.',
  },
];
---

<Layout title="Preguntas Frecuentes - Propiedades Premier">
  <!-- Header -->
  <header class="bg-signal-yellow border-b-4 border-black">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <div class="w-12 h-12 bg-black flex items-center justify-center">
          <span class="text-signal-yellow font-mono font-bold text-xl">PP</span>
        </div>
        <div>
          <h1 class="font-mono font-bold text-2xl tracking-tight">PROPIEDADES PREMIER</h1>
          <p class="font-mono text-sm text-black/70">GESTIÓN INMOBILIARIA MÉXICO</p>
        </div>
      </a>
      <nav class="hidden md:flex items-center gap-1">
        <a href="/blog" class="px-4 py-2 font-mono text-sm font-medium hover:bg-black hover:text-signal-yellow transition-colors">BLOG</a>
        {user ? (
          <a href="/dashboard" class="px-4 py-2 font-mono text-sm font-medium bg-black text-signal-yellow">DASHBOARD</a>
        ) : (
          <a href="/signin" class="px-4 py-2 font-mono text-sm font-medium bg-black text-signal-yellow">ENTRAR</a>
        )}
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="bg-concrete-200 border-b-4 border-black">
    <div class="max-w-4xl mx-auto px-6 py-16">
      <div class="inline-block bg-black text-white px-3 py-1 font-mono text-sm mb-6">SOPORTE</div>
      <h2 class="font-mono font-bold text-5xl leading-none mb-4">PREGUNTAS<br/>FRECUENTES</h2>
      <p class="text-xl text-concrete-700">Todo lo que necesitas saber sobre Propiedades Premier.</p>
    </div>
  </section>

  <!-- FAQ List -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <div class="space-y-4" id="faq-list">
        {faqs.map((faq, i) => (
          <div class="bg-white border-4 border-black faq-item">
            <button
              class="w-full text-left p-6 flex items-center justify-between gap-4 faq-trigger"
              aria-expanded="false"
              data-index={i}
            >
              <span class="font-mono font-bold text-lg">{faq.pregunta}</span>
              <span class="faq-icon font-mono font-bold text-2xl flex-shrink-0 select-none">+</span>
            </button>
            <div class="faq-answer hidden px-6 pb-6 border-t-2 border-concrete-200">
              <p class="text-concrete-600 pt-4 leading-relaxed">{faq.respuesta}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-black text-white py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h3 class="font-mono font-bold text-3xl mb-4">¿NO ENCONTRASTE TU RESPUESTA?</h3>
      <p class="text-concrete-300 mb-6">Escríbenos directamente y te ayudamos.</p>
      <a href="mailto:hola@propiedadespremier.com" class="inline-block bg-signal-yellow text-black px-8 py-4 font-mono font-bold text-lg border-4 border-signal-yellow hover:bg-white transition-colors">
        ESCRIBIR AL SOPORTE →
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-concrete-900 text-white py-12 border-t-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
            <span class="text-black font-mono font-bold">PP</span>
          </div>
          <span class="font-mono font-bold">PROPIEDADES PREMIER</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-6 text-sm">
          <a href="/" class="hover:text-signal-yellow">Inicio</a>
          <a href="/blog" class="hover:text-signal-yellow">Blog</a>
          <a href="/faq" class="hover:text-signal-yellow">FAQ</a>
          <a href="/signin" class="hover:text-signal-yellow">Entrar</a>
          <a href="/signup" class="hover:text-signal-yellow">Crear cuenta</a>
        </nav>
        <p class="text-concrete-500 text-sm">&copy; 2026 Propiedades Premier</p>
      </div>
    </div>
  </footer>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item') as HTMLElement;
        const answer = item.querySelector('.faq-answer') as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        btn.setAttribute('aria-expanded', String(!isOpen));
        answer.classList.toggle('hidden', isOpen);
        icon.textContent = isOpen ? '+' : '−';
      });
    });
  </script>
</Layout>
