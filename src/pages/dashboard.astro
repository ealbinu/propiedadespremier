---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user!;
const pb = Astro.locals.pb;

let propiedades: any[] = [];
let pagos: any[] = [];
let documentos: any[] = [];

try {
  const [pr, pa, dr] = await Promise.all([
    pb.collection('propiedades').getList(1, 50, { filter: `propietario = "${user.id}"`, sort: 'nombre' }),
    pb.collection('pagos').getList(1, 50, { filter: `usuario = "${user.id}" && estatus != "pagado"`, sort: 'fecha_vencimiento', expand: 'propiedad' }),
    pb.collection('documentos_pagos').getList(1, 50, { filter: `usuario = "${user.id}"` }),
  ]);
  propiedades = pr.items;
  pagos = pa.items;
  documentos = dr.items;
} catch {}

const hasData = propiedades.length > 0;
const userName = user.name ? user.name.split(' ')[0] : user.email.split('@')[0];
const initials = user.name
  ? user.name.split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2)
  : user.email[0].toUpperCase();

function formatMoney(n: number) {
  return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', minimumFractionDigits: 0 }).format(n || 0);
}
---

<Layout title="Dashboard - Propiedades Premier">
<div class="flex flex-col h-screen overflow-hidden bg-concrete-100">

  <!-- Top bar -->
  <header class="bg-black text-white border-b-4 border-signal-yellow flex-shrink-0">
    <div class="px-4 md:px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/" class="w-9 h-9 bg-signal-yellow flex items-center justify-center flex-shrink-0">
          <span class="text-black font-mono font-bold text-sm">PP</span>
        </a>
        <span class="font-mono font-bold text-sm hidden sm:block">PROPIEDADES PREMIER</span>
      </div>
      <div class="flex items-center gap-3">
        <a href="/blog" class="font-mono text-xs text-concrete-400 hover:text-white hidden md:block">BLOG</a>
        <div class="w-8 h-8 bg-concrete-700 border-2 border-white flex items-center justify-center">
          <span class="font-mono font-bold text-xs">{initials}</span>
        </div>
        <a href="/api/auth/signout" class="font-mono text-xs text-concrete-400 hover:text-red-400">Salir</a>
      </div>
    </div>
  </header>

  <!-- Main area -->
  <div class="flex flex-1 overflow-hidden" id="main-area">

    <!-- Chat panel -->
    <div id="chat-panel" class="flex flex-col flex-1 min-w-0 transition-all duration-500">

      <!-- Messages -->
      <div id="messages" class="flex-1 overflow-y-auto px-4 py-6">
        <div id="messages-inner" class="max-w-2xl mx-auto space-y-4">

          <!-- Welcome (shown when no messages) -->
          <div id="welcome" class="text-center py-12">
            <div class="inline-block bg-signal-yellow w-16 h-16 flex items-center justify-center border-4 border-black mb-6 mx-auto">
              <span class="font-mono font-bold text-2xl">PP</span>
            </div>
            <h1 class="font-mono font-bold text-3xl mb-3">Hola, {userName} 👋</h1>
            <p class="text-concrete-600 mb-8 max-w-md mx-auto">
              Soy tu asistente de propiedades. Puedo gestionar tus inmuebles, recibos y pagos. ¿En qué te ayudo?
            </p>

            <div class="flex flex-wrap justify-center gap-3" id="suggestions">
              <button class="suggestion-btn px-4 py-3 bg-white border-4 border-black font-mono text-sm hover:bg-signal-yellow transition-colors" data-msg="Quiero registrar una propiedad nueva">
                🏠 Nueva propiedad
              </button>
              <button class="suggestion-btn px-4 py-3 bg-white border-4 border-black font-mono text-sm hover:bg-signal-yellow transition-colors" data-msg="Quiero subir un recibo de pago">
                📄 Subir recibo
              </button>
              <button class="local-btn px-4 py-3 bg-white border-4 border-black font-mono text-sm hover:bg-signal-yellow transition-colors" data-action="pagos">
                💰 Ver pagos
              </button>
              <button class="suggestion-btn px-4 py-3 bg-white border-4 border-black font-mono text-sm hover:bg-signal-yellow transition-colors" data-msg="Muéstrame el calendario de pagos próximos">
                📅 Calendario
              </button>
            </div>
          </div>

        </div>
      </div>

      <!-- Input area -->
      <div class="flex-shrink-0 border-t-4 border-black bg-white px-4 py-4">
        <div class="max-w-2xl mx-auto">

          <!-- File preview -->
          <div id="file-preview" class="hidden mb-3 p-3 bg-concrete-100 border-2 border-black flex items-center gap-3">
            <span class="text-2xl" id="file-icon">📄</span>
            <div class="flex-1 min-w-0">
              <div class="font-mono text-sm font-bold truncate" id="file-name"></div>
              <div class="font-mono text-xs text-concrete-500" id="file-size"></div>
            </div>
            <button id="file-remove" class="w-6 h-6 flex items-center justify-center border-2 border-black bg-white hover:bg-red-100 font-bold text-sm">×</button>
          </div>

          <div class="flex gap-2">
            <label class="flex-shrink-0 w-11 h-11 bg-concrete-100 border-2 border-black flex items-center justify-center cursor-pointer hover:bg-signal-yellow transition-colors">
              <span class="text-lg">📎</span>
              <input type="file" id="file-input" accept="application/pdf,image/*" class="hidden" />
            </label>
            <input
              type="text"
              id="chat-input"
              placeholder="Escribe un mensaje o sube un archivo..."
              class="flex-1 px-4 py-2 border-2 border-black font-mono text-sm focus:outline-none focus:border-signal-yellow"
              autocomplete="off"
            />
            <button id="send-btn" class="flex-shrink-0 px-5 py-2 bg-black text-white font-mono font-bold border-2 border-black hover:bg-signal-yellow hover:text-black transition-colors">
              →
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Data panel (right) -->
    <div id="data-panel" class="hidden lg:flex flex-col w-[420px] flex-shrink-0 border-l-4 border-black bg-white overflow-hidden">
      <!-- Tabs -->
      <div class="flex border-b-4 border-black flex-shrink-0" id="panel-tabs">
        <button class="panel-tab flex-1 px-3 py-3 font-mono text-xs font-bold bg-signal-yellow border-r-2 border-black" data-tab="props">PROPIEDADES</button>
        <button class="panel-tab flex-1 px-3 py-3 font-mono text-xs font-bold bg-concrete-100 hover:bg-concrete-200 border-r-2 border-black" data-tab="pagos">PAGOS</button>
        <button class="panel-tab flex-1 px-3 py-3 font-mono text-xs font-bold bg-concrete-100 hover:bg-concrete-200" data-tab="docs">RECIBOS</button>
      </div>

      <!-- Tab content -->
      <div class="flex-1 overflow-y-auto" id="panel-content">

        <!-- Properties -->
        <div id="tab-props" class="p-4 space-y-3">
          <div id="props-list"></div>
        </div>

        <!-- Payments -->
        <div id="tab-pagos" class="hidden p-4 space-y-3">
          <div id="pagos-list"></div>
        </div>

        <!-- Documents -->
        <div id="tab-docs" class="hidden p-4 space-y-3">
          <div id="docs-list"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<script define:vars={{ propiedades, pagos, documentos, hasData }}>

// ─── Markdown renderer ────────────────────────────────────────────────────
function renderMd(src) {
  if (!src) return '';
  let html = src;

  // Escape HTML
  html = html.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  // Code blocks ```lang\n...\n```
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) =>
    `<pre class="bg-concrete-900 text-green-400 p-3 my-2 overflow-x-auto text-xs border-2 border-black"><code>${code.trim()}</code></pre>`
  );

  // Inline code `...`
  html = html.replace(/`([^`]+)`/g, '<code class="bg-concrete-200 text-black px-1 py-0.5 text-xs border border-concrete-400">$1</code>');

  // Headers ### ## #
  html = html.replace(/^### (.+)$/gm, '<h4 class="font-bold text-base mt-3 mb-1">$1</h4>');
  html = html.replace(/^## (.+)$/gm, '<h3 class="font-bold text-lg mt-3 mb-1">$1</h3>');
  html = html.replace(/^# (.+)$/gm, '<h2 class="font-bold text-xl mt-3 mb-1">$1</h2>');

  // Bold **text**
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

  // Italic *text*
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

  // Horizontal rule ---
  html = html.replace(/^---$/gm, '<hr class="border-t-2 border-concrete-300 my-3"/>');

  // Tables
  html = html.replace(/^(\|.+\|)\n(\|[\s\-:|]+\|)\n((?:\|.+\|\n?)+)/gm, (_, headerRow, sepRow, bodyRows) => {
    const headers = headerRow.split('|').filter(c => c.trim());
    const rows = bodyRows.trim().split('\n').map(r => r.split('|').filter(c => c.trim()));
    let t = '<table class="w-full my-2 border-2 border-black text-xs">';
    t += '<thead class="bg-black text-white"><tr>' + headers.map(h => `<th class="p-2 text-left">${h.trim()}</th>`).join('') + '</tr></thead>';
    t += '<tbody>' + rows.map(r => '<tr class="border-t border-concrete-300">' + r.map(c => `<td class="p-2">${c.trim()}</td>`).join('') + '</tr>').join('') + '</tbody>';
    t += '</table>';
    return t;
  });

  // Unordered lists (- item)
  html = html.replace(/^((?:- .+\n?)+)/gm, (block) => {
    const items = block.trim().split('\n').map(l => l.replace(/^- /, ''));
    return '<ul class="list-none space-y-1 my-2">' + items.map(i => `<li class="flex gap-2"><span class="text-signal-yellow flex-shrink-0">▸</span><span>${i}</span></li>`).join('') + '</ul>';
  });

  // Ordered lists (1. item)
  html = html.replace(/^((?:\d+\. .+\n?)+)/gm, (block) => {
    const items = block.trim().split('\n').map(l => l.replace(/^\d+\. /, ''));
    return '<ol class="list-none space-y-1 my-2 counter-reset">' + items.map((item, i) => `<li class="flex gap-2"><span class="text-signal-yellow flex-shrink-0 font-bold">${i+1}.</span><span>${item}</span></li>`).join('') + '</ol>';
  });

  // Blockquote > text
  html = html.replace(/^&gt; (.+)$/gm, '<blockquote class="border-l-4 border-signal-yellow pl-3 my-2 text-concrete-500 italic">$1</blockquote>');

  // Links [text](url)
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener" class="underline text-signal-yellow hover:text-white">$1</a>');

  // Paragraphs (double newline)
  html = html.replace(/\n\n/g, '</p><p class="mt-2">');

  // Single newlines → <br>
  html = html.replace(/\n/g, '<br/>');

  // Wrap in paragraph
  html = '<p>' + html + '</p>';

  // Clean empty paragraphs
  html = html.replace(/<p>\s*<\/p>/g, '');
  html = html.replace(/<p>\s*(<(?:h[1-4]|ul|ol|pre|table|blockquote|hr))/g, '$1');
  html = html.replace(/(<\/(?:h[1-4]|ul|ol|pre|table|blockquote|hr)>)\s*<\/p>/g, '$1');

  return html;
}

// ─── State ────────────────────────────────────────────────────────────────
const conversationHistory = [];
let pendingFile = null;
let currentPanelData = { propiedades, pagos, documentos };

// ─── DOM refs ─────────────────────────────────────────────────────────────
const messagesDiv    = document.getElementById('messages-inner');
const welcomeDiv     = document.getElementById('welcome');
const chatInput      = document.getElementById('chat-input');
const sendBtn        = document.getElementById('send-btn');
const fileInput      = document.getElementById('file-input');
const filePreview    = document.getElementById('file-preview');
const fileName       = document.getElementById('file-name');
const fileSize       = document.getElementById('file-size');
const fileIcon       = document.getElementById('file-icon');
const fileRemove     = document.getElementById('file-remove');
const dataPanel      = document.getElementById('data-panel');
const messagesScroll = document.getElementById('messages');

// ─── Panel rendering ──────────────────────────────────────────────────────
function updatePanel(data) {
  currentPanelData = data || currentPanelData;
  const d = currentPanelData;
  const hasAnyData = d.propiedades.length > 0 || d.pagos.length > 0 || d.documentos.length > 0;

  if (hasAnyData) {
    dataPanel.classList.remove('hidden');
    dataPanel.classList.add('lg:flex');
  }

  // Properties
  document.getElementById('props-list').innerHTML = d.propiedades.length > 0
    ? d.propiedades.map(p => `
      <div class="p-3 border-2 border-black hover:bg-signal-yellow transition-colors cursor-pointer" onclick="showPropertyLocal('${p.id}')">
        <div class="font-mono font-bold text-sm">${p.nombre}</div>
        <div class="font-mono text-xs text-concrete-500">${p.direccion || ''} ${p.ciudad ? '· ' + p.ciudad : ''}</div>
        <div class="font-mono text-xs text-concrete-400 mt-1">${p.tipo || 'propiedad'}</div>
      </div>`).join('')
    : '<div class="font-mono text-sm text-concrete-500 text-center py-8">Sin propiedades</div>';

  // Payments
  document.getElementById('pagos-list').innerHTML = d.pagos.length > 0
    ? d.pagos.map(p => {
        const days = p.fecha_vencimiento ? Math.ceil((new Date(p.fecha_vencimiento).getTime() - Date.now()) / 86400000) : null;
        const color = days !== null && days < 0 ? 'border-red-500 bg-red-50' : days !== null && days <= 7 ? 'border-yellow-500 bg-yellow-50' : 'border-black';
        return `<div class="p-3 border-2 ${color}">
          <div class="flex justify-between items-start">
            <div class="font-mono font-bold text-sm">${p.concepto}</div>
            <div class="font-mono font-bold text-sm">$${(p.monto || 0).toLocaleString('es-MX')}</div>
          </div>
          <div class="font-mono text-xs text-concrete-500 mt-1">${p.fecha_vencimiento ? new Date(p.fecha_vencimiento).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'}) : '—'}</div>
        </div>`;
      }).join('')
    : '<div class="font-mono text-sm text-concrete-500 text-center py-8">Sin pagos pendientes</div>';

  // Documents
  document.getElementById('docs-list').innerHTML = d.documentos.length > 0
    ? d.documentos.map(doc => `
      <div class="p-3 border-2 border-concrete-300">
        <div class="font-mono font-bold text-sm truncate">${doc.titulo || doc.archivo}</div>
        <div class="font-mono text-xs text-concrete-500">${doc.categoria || 'sin categoría'} ${doc.proveedor ? '· ' + doc.proveedor : ''}</div>
        ${doc.monto ? `<div class="font-mono text-xs mt-1">$${doc.monto.toLocaleString('es-MX')}</div>` : ''}
      </div>`).join('')
    : '<div class="font-mono text-sm text-concrete-500 text-center py-8">Sin recibos</div>';
}

// Tabs
document.querySelectorAll('.panel-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.panel-tab').forEach(t => { t.classList.remove('bg-signal-yellow'); t.classList.add('bg-concrete-100'); });
    tab.classList.remove('bg-concrete-100');
    tab.classList.add('bg-signal-yellow');
    const target = tab.dataset.tab;
    document.getElementById('tab-props').classList.toggle('hidden', target !== 'props');
    document.getElementById('tab-pagos').classList.toggle('hidden', target !== 'pagos');
    document.getElementById('tab-docs').classList.toggle('hidden', target !== 'docs');
  });
});

// ─── Messages ─────────────────────────────────────────────────────────────
function scrollToBottom() {
  setTimeout(() => { messagesScroll.scrollTop = messagesScroll.scrollHeight; }, 50);
}

function addMessage(role, content, attachments) {
  if (welcomeDiv) welcomeDiv.classList.add('hidden');

  const isUser = role === 'user';
  const wrapper = document.createElement('div');
  wrapper.className = `flex ${isUser ? 'justify-end' : 'justify-start'}`;

  let html = `<div class="max-w-[85%] ${isUser
    ? 'bg-black text-white border-4 border-black'
    : 'bg-white border-4 border-black'
  } px-4 py-3">`;

  // Markdown → HTML
  html += `<div class="font-mono text-sm leading-relaxed chat-md">${renderMd(content)}</div>`;

  // Attachments
  if (attachments && attachments.length > 0) {
    for (const att of attachments) {
      if (att.type === 'property') {
        const p = att.data;
        html += `<div class="mt-3 p-3 bg-signal-yellow border-2 border-black text-black">
          <div class="font-mono font-bold">🏠 ${p.nombre}</div>
          <div class="font-mono text-xs">${p.direccion || ''} ${p.ciudad ? '· ' + p.ciudad : ''}</div>
        </div>`;
      }
      if (att.type === 'properties_list') {
        for (const p of att.data) {
          html += `<div class="mt-2 p-2 bg-concrete-100 border border-concrete-300 text-black">
            <div class="font-mono font-bold text-xs">🏠 ${p.nombre}</div>
            <div class="font-mono text-xs text-concrete-500">${p.direccion || ''}</div>
          </div>`;
        }
      }
      if (att.type === 'payments_list') {
        for (const p of att.data.slice(0, 10)) {
          html += `<div class="mt-2 p-2 bg-concrete-100 border border-concrete-300 text-black flex justify-between">
            <div class="font-mono text-xs">${p.concepto}</div>
            <div class="font-mono text-xs font-bold">$${(p.monto||0).toLocaleString('es-MX')}</div>
          </div>`;
        }
      }
      if (att.type === 'document') {
        const d = att.data;
        html += `<div class="mt-3 p-3 bg-concrete-100 border-2 border-concrete-300 text-black">
          <div class="font-mono font-bold text-xs">📄 ${d.titulo || d.archivo}</div>
          <div class="font-mono text-xs text-concrete-500">${d.categoria || ''} ${d.proveedor ? '· ' + d.proveedor : ''} ${d.monto ? '· $' + d.monto.toLocaleString('es-MX') : ''}</div>
        </div>`;
      }
    }
  }

  html += '</div>';
  wrapper.innerHTML = html;
  messagesDiv.appendChild(wrapper);
  scrollToBottom();
}

function addTypingIndicator() {
  const el = document.createElement('div');
  el.id = 'typing';
  el.className = 'flex justify-start';
  el.innerHTML = `<div class="bg-white border-4 border-black px-4 py-3">
    <div class="flex gap-1 items-center">
      <div class="w-2 h-2 bg-black rounded-full animate-bounce" style="animation-delay:0ms"></div>
      <div class="w-2 h-2 bg-black rounded-full animate-bounce" style="animation-delay:150ms"></div>
      <div class="w-2 h-2 bg-black rounded-full animate-bounce" style="animation-delay:300ms"></div>
    </div>
  </div>`;
  messagesDiv.appendChild(el);
  scrollToBottom();
}

function removeTypingIndicator() {
  document.getElementById('typing')?.remove();
}

// ─── Send message ─────────────────────────────────────────────────────────
async function sendMessage(text) {
  if (!text && !pendingFile) return;

  const userText = text || (pendingFile ? `Subí un archivo: ${pendingFile.name}` : '');

  // Show user message
  addMessage('user', userText);
  conversationHistory.push({ role: 'user', content: userText });
  chatInput.value = '';

  let documentId = null;

  // Upload file if pending
  if (pendingFile) {
    addTypingIndicator();
    try {
      const fd = new FormData();
      fd.append('archivo', pendingFile);
      const upRes = await fetch('/api/upload', { method: 'POST', body: fd });
      const upData = await upRes.json();
      if (upData.ok && upData.document) {
        documentId = upData.document.id;
      }
    } catch {}
    clearFile();
    removeTypingIndicator();
  }

  // Send to chat API
  addTypingIndicator();
  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: conversationHistory,
        documentId,
      }),
    });
    const data = await res.json();
    removeTypingIndicator();

    conversationHistory.push({ role: 'assistant', content: data.reply });
    addMessage('assistant', data.reply, data.attachments);
    updatePanel(data.panelData);

  } catch (err) {
    removeTypingIndicator();
    addMessage('assistant', 'Error de conexión. Intenta de nuevo.');
  }
}

// ─── File handling ────────────────────────────────────────────────────────
function clearFile() {
  pendingFile = null;
  filePreview.classList.add('hidden');
  fileInput.value = '';
}

fileInput.addEventListener('change', () => {
  const f = fileInput.files?.[0];
  if (!f) return;
  pendingFile = f;
  fileName.textContent = f.name;
  fileSize.textContent = (f.size / 1024).toFixed(0) + ' KB';
  fileIcon.textContent = f.type.startsWith('image/') ? '🖼️' : '📄';
  filePreview.classList.remove('hidden');
});

fileRemove.addEventListener('click', clearFile);

// ─── Events ───────────────────────────────────────────────────────────────
sendBtn.addEventListener('click', () => sendMessage(chatInput.value.trim()));
chatInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage(chatInput.value.trim());
  }
});

// Suggestion buttons (AI)
document.querySelectorAll('.suggestion-btn').forEach(btn => {
  btn.addEventListener('click', () => sendMessage(btn.dataset.msg));
});

// Local buttons (no AI)
document.querySelectorAll('.local-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const action = btn.dataset.action;
    if (action === 'pagos') showPagosLocal();
  });
});

// ─── Local rendering (no AI calls) ────────────────────────────────────────

function fmtMoney(n) {
  return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', minimumFractionDigits: 0 }).format(n || 0);
}
function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
}

window.showPropertyLocal = (propId) => {
  const d = currentPanelData;
  const p = d.propiedades.find(x => x.id === propId);
  if (!p) return;

  const propPagos = d.pagos.filter(x => x.propiedad === propId);
  const propDocs = d.documentos.filter(x => x.propiedad === propId);

  if (welcomeDiv) welcomeDiv.classList.add('hidden');

  let md = `### 🏠 ${p.nombre}\n`;
  md += `**Tipo:** ${p.tipo || 'propiedad'}\n`;
  if (p.direccion) md += `**Dirección:** ${p.direccion}\n`;
  if (p.ciudad || p.estado) md += `**Ubicación:** ${[p.ciudad, p.estado].filter(Boolean).join(', ')}\n`;
  md += `\n---\n`;

  if (propPagos.length > 0) {
    md += `\n**Pagos pendientes (${propPagos.length}):**\n`;
    for (const pg of propPagos) {
      const days = pg.fecha_vencimiento ? Math.ceil((new Date(pg.fecha_vencimiento).getTime() - Date.now()) / 86400000) : null;
      const tag = days !== null && days < 0 ? '🔴 VENCIDO' : days !== null && days <= 7 ? '🟡 PRÓXIMO' : '';
      md += `- ${pg.concepto}: **${fmtMoney(pg.monto)}** — ${fmtDate(pg.fecha_vencimiento)} ${tag}\n`;
    }
  } else {
    md += `\n✅ Sin pagos pendientes\n`;
  }

  if (propDocs.length > 0) {
    md += `\n**Recibos guardados (${propDocs.length}):**\n`;
    for (const doc of propDocs) {
      md += `- 📄 ${doc.titulo || doc.archivo}${doc.monto ? ' — ' + fmtMoney(doc.monto) : ''}\n`;
    }
  }

  md += `\n---\n*Pregúntame algo sobre esta propiedad o sube un recibo.*`;

  addMessage('assistant', md, [{ type: 'property', data: p }]);
};

window.showPagosLocal = () => {
  const d = currentPanelData;
  if (welcomeDiv) welcomeDiv.classList.add('hidden');

  if (d.pagos.length === 0) {
    addMessage('assistant', '✅ No tienes pagos pendientes.');
    return;
  }

  let md = `### 💰 Pagos pendientes (${d.pagos.length})\n\n`;
  const total = d.pagos.reduce((s, p) => s + (p.monto || 0), 0);
  md += `**Total por pagar: ${fmtMoney(total)}**\n\n`;

  for (const pg of d.pagos) {
    const days = pg.fecha_vencimiento ? Math.ceil((new Date(pg.fecha_vencimiento).getTime() - Date.now()) / 86400000) : null;
    const tag = days !== null && days < 0 ? '🔴 VENCIDO' : days !== null && days <= 7 ? '🟡' : '';
    const prop = d.propiedades.find(p => p.id === pg.propiedad);
    md += `- **${pg.concepto}**: ${fmtMoney(pg.monto)} — ${fmtDate(pg.fecha_vencimiento)} ${tag}${prop ? ' · ' + prop.nombre : ''}\n`;
  }

  addMessage('assistant', md, [{ type: 'payments_list', data: d.pagos }]);
};

// Drag and drop
const chatPanel = document.getElementById('chat-panel');
chatPanel.addEventListener('dragover', (e) => { e.preventDefault(); chatPanel.classList.add('ring-4', 'ring-signal-yellow'); });
chatPanel.addEventListener('dragleave', () => chatPanel.classList.remove('ring-4', 'ring-signal-yellow'));
chatPanel.addEventListener('drop', (e) => {
  e.preventDefault();
  chatPanel.classList.remove('ring-4', 'ring-signal-yellow');
  const f = e.dataTransfer?.files?.[0];
  if (f) {
    pendingFile = f;
    fileName.textContent = f.name;
    fileSize.textContent = (f.size / 1024).toFixed(0) + ' KB';
    fileIcon.textContent = f.type.startsWith('image/') ? '🖼️' : '📄';
    filePreview.classList.remove('hidden');
    sendMessage(`Subí un archivo: ${f.name}`);
  }
});

// Init
updatePanel(currentPanelData);

</script>
</Layout>
