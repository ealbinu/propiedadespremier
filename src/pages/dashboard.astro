---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user!;
const pb = Astro.locals.pb;

// Fetch user's properties
let propiedades: any[] = [];
let pagos: any[] = [];
try {
  const propResult = await pb.collection('propiedades').getFullList({
    filter: `propietario = "${user.id}"`,
    sort: '-created',
  });
  propiedades = propResult;

  const pagosResult = await pb.collection('pagos').getList(1, 10, {
    filter: `usuario = "${user.id}" && estatus != "pagado"`,
    sort: 'fecha_vencimiento',
    expand: 'propiedad',
  });
  pagos = pagosResult.items;
} catch (e) {
  // Collections may be empty
}

// Calculate stats
const totalPendiente = pagos.reduce((sum, p) => sum + (p.monto || 0), 0);
const now = new Date();
const proximoVencimiento = pagos.length > 0 && pagos[0].fecha_vencimiento
  ? Math.max(0, Math.ceil((new Date(pagos[0].fecha_vencimiento).getTime() - now.getTime()) / (1000 * 60 * 60 * 24)))
  : null;

function formatMoney(amount: number) {
  return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', minimumFractionDigits: 0 }).format(amount);
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
}

function getDaysLabel(days: number) {
  if (days <= 0) return 'HOY';
  return `${days}d`;
}

function getUrgencyClass(dateStr: string) {
  if (!dateStr) return 'bg-concrete-300';
  const days = Math.ceil((new Date(dateStr).getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
  if (days <= 3) return 'bg-red-500';
  if (days <= 15) return 'bg-signal-yellow';
  return 'bg-concrete-300';
}

function getUrgencyLabel(dateStr: string) {
  if (!dateStr) return '—';
  const days = Math.ceil((new Date(dateStr).getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
  if (days <= 0) return 'HOY';
  if (days <= 3) return 'URG';
  return `${days}D`;
}

const userName = user.name ? user.name.split(' ')[0].toUpperCase() : user.email.split('@')[0].toUpperCase();
const initials = user.name
  ? user.name.split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2)
  : user.email[0].toUpperCase();
---

<Layout title="Dashboard - Propiedades Premier">
  <div class="flex flex-col min-h-screen">
    <!-- Header -->
    <header class="bg-black text-white border-b-4 border-signal-yellow">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
            <span class="text-black font-mono font-bold">PP</span>
          </a>
          <span class="font-mono font-bold text-lg hidden sm:block">PROPIEDADES PREMIER</span>
        </div>

        <div class="flex items-center gap-4">
          <div class="flex items-center gap-3">
            <span class="font-mono text-sm hidden sm:block">{user.email}</span>
            <div class="w-10 h-10 bg-concrete-700 border-2 border-white flex items-center justify-center">
              <span class="font-mono font-bold">{initials}</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="flex flex-1">
      <!-- Sidebar -->
      <aside class="w-64 bg-concrete-900 text-white border-r-4 border-black hidden lg:block">
        <nav class="p-4">
          <div class="mb-6">
            <span class="font-mono text-xs text-concrete-400">MENÚ PRINCIPAL</span>
          </div>

          <ul class="space-y-1">
            <li>
              <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 bg-signal-yellow text-black font-mono font-medium">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                </svg>
                DASHBOARD
              </a>
            </li>
            <li>
              <a href="/propiedades" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                MIS PROPIEDADES
              </a>
            </li>
            <li>
              <a href="/pagos" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
                PAGOS
              </a>
            </li>
            <li>
              <a href="/blog" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                </svg>
                BLOG
              </a>
            </li>
          </ul>

          <div class="mt-8 mb-6">
            <span class="font-mono text-xs text-concrete-400">CUENTA</span>
          </div>

          <ul class="space-y-1">
            <li>
              <a href="/api/auth/signout" class="flex items-center gap-3 px-4 py-3 hover:bg-red-900 font-mono text-sm transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                CERRAR SESIÓN
              </a>
            </li>
          </ul>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 p-6">
        <!-- Welcome -->
        <div class="mb-8">
          <h1 class="font-mono font-bold text-3xl mb-2">BIENVENIDO, {userName}</h1>
          <p class="text-concrete-600">Aquí está el resumen de tus propiedades</p>
        </div>

        <!-- Stats Grid -->
        <div class="grid md:grid-cols-4 gap-4 mb-8">
          <div class="bg-white border-4 border-black p-6">
            <div class="font-mono text-sm text-concrete-500 mb-2">PROPIEDADES</div>
            <div class="font-mono font-bold text-4xl">{propiedades.length}</div>
          </div>
          <div class="bg-signal-yellow border-4 border-black p-6">
            <div class="font-mono text-sm text-black/70 mb-2">PAGOS PENDIENTES</div>
            <div class="font-mono font-bold text-4xl">{pagos.length}</div>
          </div>
          <div class="bg-white border-4 border-black p-6">
            <div class="font-mono text-sm text-concrete-500 mb-2">PROX. VENCIMIENTO</div>
            <div class="font-mono font-bold text-4xl">
              {proximoVencimiento !== null ? getDaysLabel(proximoVencimiento) : '—'}
            </div>
          </div>
          <div class="bg-concrete-800 text-white border-4 border-black p-6">
            <div class="font-mono text-sm text-concrete-300 mb-2">TOTAL POR PAGAR</div>
            <div class="font-mono font-bold text-4xl">{formatMoney(totalPendiente)}</div>
          </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-6">
          <!-- Pending Payments -->
          <div class="lg:col-span-2">
            <div class="bg-white border-4 border-black">
              <div class="p-6 border-b-4 border-black flex items-center justify-between">
                <h2 class="font-mono font-bold text-xl">PAGOS PENDIENTES</h2>
                <a href="/pagos" class="font-mono text-sm underline hover:no-underline">VER TODOS</a>
              </div>

              {pagos.length > 0 ? (
                <div class="divide-y-2 divide-concrete-200">
                  {pagos.map((pago: any) => (
                    <div class="p-6 flex items-center justify-between hover:bg-concrete-50 transition-colors">
                      <div class="flex items-center gap-4">
                        <div class={`w-12 h-12 ${getUrgencyClass(pago.fecha_vencimiento)} border-2 border-black flex items-center justify-center`}>
                          <span class={`font-mono font-bold text-xs ${pago.fecha_vencimiento && Math.ceil((new Date(pago.fecha_vencimiento).getTime() - now.getTime()) / (1000*60*60*24)) <= 3 ? 'text-white' : 'text-black'}`}>
                            {getUrgencyLabel(pago.fecha_vencimiento)}
                          </span>
                        </div>
                        <div>
                          <div class="font-mono font-bold">{pago.concepto}{pago.expand?.propiedad ? ` - ${pago.expand.propiedad.nombre}` : ''}</div>
                          <div class="text-sm text-concrete-500">Vence: {formatDate(pago.fecha_vencimiento)}</div>
                        </div>
                      </div>
                      <div class="text-right">
                        <div class="font-mono font-bold text-xl">{formatMoney(pago.monto)}</div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="p-12 text-center">
                  <p class="font-mono text-concrete-500">No tienes pagos pendientes</p>
                </div>
              )}
            </div>
          </div>

          <!-- Side Panel -->
          <div class="space-y-6">
            <!-- Quick Actions -->
            <div class="bg-black text-white border-4 border-black">
              <div class="p-6 border-b-4 border-concrete-700">
                <h3 class="font-mono font-bold">ACCIONES RÁPIDAS</h3>
              </div>
              <div class="p-6 space-y-3">
                <a href="/propiedades?action=nueva" class="block w-full py-3 px-4 bg-signal-yellow text-black font-mono font-bold text-center border-2 border-signal-yellow hover:bg-white transition-colors">
                  + AGREGAR PROPIEDAD
                </a>
                <a href="/pagos?action=nuevo" class="block w-full py-3 px-4 bg-concrete-800 text-white font-mono font-bold text-center border-2 border-concrete-600 hover:bg-concrete-700 transition-colors">
                  + REGISTRAR PAGO
                </a>
              </div>
            </div>

            <!-- Properties Mini List -->
            <div class="bg-white border-4 border-black">
              <div class="p-4 border-b-4 border-black">
                <h3 class="font-mono font-bold">MIS PROPIEDADES</h3>
              </div>
              {propiedades.length > 0 ? (
                <div class="divide-y-2 divide-concrete-200">
                  {propiedades.map((prop: any) => (
                    <a href={`/propiedades?id=${prop.id}`} class="block p-4 hover:bg-signal-yellow transition-colors">
                      <div class="font-mono font-bold">{prop.nombre}</div>
                      <div class="text-sm text-concrete-500">{prop.direccion}</div>
                    </a>
                  ))}
                </div>
              ) : (
                <div class="p-6 text-center">
                  <p class="text-concrete-500 text-sm mb-3">No tienes propiedades registradas</p>
                  <a href="/propiedades?action=nueva" class="font-mono text-sm font-bold underline">AGREGAR UNA</a>
                </div>
              )}
              {propiedades.length > 0 && (
                <a href="/propiedades" class="block p-4 text-center font-mono text-sm underline hover:bg-concrete-100">
                  VER TODAS →
                </a>
              )}
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Mobile Nav -->
    <nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-black text-white border-t-4 border-signal-yellow flex justify-around py-3">
      <a href="/dashboard" class="flex flex-col items-center text-signal-yellow">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"/></svg>
        <span class="font-mono text-xs mt-1">INICIO</span>
      </a>
      <a href="/propiedades" class="flex flex-col items-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span class="font-mono text-xs mt-1">PROPS</span>
      </a>
      <a href="/pagos" class="flex flex-col items-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <span class="font-mono text-xs mt-1">PAGOS</span>
      </a>
      <a href="/api/auth/signout" class="flex flex-col items-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        <span class="font-mono text-xs mt-1">SALIR</span>
      </a>
    </nav>
  </div>
</Layout>
