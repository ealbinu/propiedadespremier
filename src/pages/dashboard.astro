---
// Dashboard - User Panel
// const user = Astro.locals.user;
// if (!user) return Astro.redirect('/signin');
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Propiedades Premier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    @import "tailwindcss";
    @theme {
      --color-concrete-50: #f7f7f7;
      --color-concrete-100: #e3e3e3;
      --color-concrete-200: #c8c8c8;
      --color-concrete-300: #a4a4a4;
      --color-concrete-400: #818181;
      --color-concrete-500: #666666;
      --color-concrete-600: #515151;
      --color-concrete-700: #434343;
      --color-concrete-800: #383838;
      --color-concrete-900: #2d2d2d;
      --color-concrete-950: #1a1a1a;
      --color-asphalt: #2f2f2f;
      --color-signal-yellow: #f7c600;
    }
  </style>
</head>
<body class="bg-concrete-100 text-concrete-900 font-sans antialiased">
  
  <!-- Header -->
  <header class="bg-black text-white border-b-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
          <span class="text-black font-mono font-bold">PP</span>
        </div>
        <span class="font-mono font-bold text-lg hidden sm:block">PROPIEDADES PREMIER</span>
      </div>
      
      <div class="flex items-center gap-4">
        <button class="relative p-2 hover:bg-concrete-800 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="absolute top-1 right-1 w-3 h-3 bg-red-500 border-2 border-black"></span>
        </button>
        
        <div class="flex items-center gap-3">
          <span class="font-mono text-sm hidden sm:block">juan@ejemplo.com</span>
          <div class="w-10 h-10 bg-concrete-700 border-2 border-white flex items-center justify-center">
            <span class="font-mono font-bold">JP</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-concrete-900 text-white min-h-screen border-r-4 border-black hidden lg:block">
      <nav class="p-4">
        <div class="mb-6">
          <span class="font-mono text-xs text-concrete-400">MENÚ PRINCIPAL</span>
        </div>
        
        <ul class="space-y-1">
          <li>
            <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 bg-signal-yellow text-black font-mono font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
              DASHBOARD
            </a>
          </li>
          <li>
            <a href="/propiedades" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              MIS PROPIEDADES
            </a>
          </li>
          <li>
            <a href="/pagos" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
              PAGOS
            </a>
          </li>
          <li>
            <a href="/alertas" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              ALERTAS
            </a>
          </li>
        </ul>

        <div class="mt-8 mb-6">
          <span class="font-mono text-xs text-concrete-400">CONFIGURACIÓN</span>
        </div>
        
        <ul class="space-y-1">
          <li>
            <a href="/perfil" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              PERFIL
            </a>
          </li>
          <li>
            <a href="/logout" class="flex items-center gap-3 px-4 py-3 hover:bg-red-900 font-mono text-sm transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
              CERRAR SESIÓN
            </a>
          </li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-6">
      <!-- Welcome -->
      <div class="mb-8">
        <h1 class="font-mono font-bold text-3xl mb-2">BIENVENIDO, JUAN</h1>
        <p class="text-concrete-600">Aquí está el resumen de tus propiedades</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white border-4 border-black p-6">
          <div class="font-mono text-sm text-concrete-500 mb-2">PROPIEDADES</div>
          <div class="font-mono font-bold text-4xl">3</div>
        </div>
        <div class="bg-signal-yellow border-4 border-black p-6">
          <div class="font-mono text-sm text-black/70 mb-2">PAGOS PENDIENTES</div>
          <div class="font-mono font-bold text-4xl">5</div>
        </div>
        <div class="bg-white border-4 border-black p-6">
          <div class="font-mono text-sm text-concrete-500 mb-2">PROX. VENCIMIENTO</div>
          <div class="font-mono font-bold text-4xl">3<span class="text-lg">d</span></div>
        </div>
        <div class="bg-concrete-800 text-white border-4 border-black p-6">
          <div class="font-mono text-sm text-concrete-300 mb-2">TOTAL POR PAGAR</div>
          <div class="font-mono font-bold text-4xl">$8,420</div>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        <!-- Pending Payments -->
        <div class="lg:col-span-2">
          <div class="bg-white border-4 border-black">
            <div class="p-6 border-b-4 border-black flex items-center justify-between">
              <h2 class="font-mono font-bold text-xl">PAGOS PENDIENTES</h2>
              <a href="/pagos" class="font-mono text-sm underline hover:no-underline">VER TODOS</a>
            </div>
            
            <div class="divide-y-2 divide-concrete-200">
              <!-- Payment Item -->
              <div class="p-6 flex items-center justify-between hover:bg-concrete-50 transition-colors">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-red-500 border-2 border-black flex items-center justify-center">
                    <span class="text-white font-mono font-bold text-xs">URG</span>
                  </div>
                  <div>
                    <div class="font-mono font-bold">Predial - Casa Zapopan</div>
                    <div class="text-sm text-concrete-500">Vence: 15 Mar 2026</div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-mono font-bold text-xl">$2,450 MXN</div>
                  <button class="mt-2 px-4 py-1 bg-black text-white font-mono text-xs hover:bg-signal-yellow hover:text-black transition-colors">
                    PAGAR
                  </button>
                </div>
              </div>

              <!-- Payment Item -->
              <div class="p-6 flex items-center justify-between hover:bg-concrete-50 transition-colors">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-signal-yellow border-2 border-black flex items-center justify-center">
                    <span class="text-black font-mono font-bold text-xs">15D</span>
                  </div>
                  <div>
                    <div class="font-mono font-bold">Luz - Depto CDMX</div>
                    <div class="text-sm text-concrete-500">Vence: 25 Mar 2026</div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-mono font-bold text-xl">$1,280 MXN</div>
                  <button class="mt-2 px-4 py-1 bg-black text-white font-mono text-xs hover:bg-signal-yellow hover:text-black transition-colors">
                    PAGAR
                  </button>
                </div>
              </div>

              <!-- Payment Item -->
              <div class="p-6 flex items-center justify-between hover:bg-concrete-50 transition-colors">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-concrete-300 border-2 border-black flex items-center justify-center">
                    <span class="text-black font-mono font-bold text-xs">30D</span>
                  </div>
                  <div>
                    <div class="font-mono font-bold">Agua - Terreno GDL</div>
                    <div class="text-sm text-concrete-500">Vence: 10 Abr 2026</div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-mono font-bold text-xl">$890 MXN</div>
                  <button class="mt-2 px-4 py-1 bg-black text-white font-mono text-xs hover:bg-signal-yellow hover:text-black transition-colors">
                    PAGAR
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Side Panel -->
        <div class="space-y-6">
          <!-- Quick Actions -->
          <div class="bg-black text-white border-4 border-black">
            <div class="p-6 border-b-4 border-concrete-700">
              <h3 class="font-mono font-bold">ACCIONES RÁPIDAS</h3>
            </div>
            <div class="p-6 space-y-3">
              <a href="/propiedades/nueva" class="block w-full py-3 px-4 bg-signal-yellow text-black font-mono font-bold text-center border-2 border-signal-yellow hover:bg-white transition-colors">
                + AGREGAR PROPIEDAD
              </a>
              <a href="/pagos/nuevo" class="block w-full py-3 px-4 bg-concrete-800 text-white font-mono font-bold text-center border-2 border-concrete-600 hover:bg-concrete-700 transition-colors">
                + REGISTRAR PAGO
              </a>
              <a href="/linea-captura" class="block w-full py-3 px-4 bg-transparent text-white font-mono font-bold text-center border-2 border-white hover:bg-white hover:text-black transition-colors">
                GENERAR LÍNEA DE CAPTURA
              </a>
            </div>
          </div>

          <!-- Properties Mini List -->
          <div class="bg-white border-4 border-black">
            <div class="p-4 border-b-4 border-black">
              <h3 class="font-mono font-bold">MIS PROPIEDADES</h3>
            </div>
            <div class="divide-y-2 divide-concrete-200">
              <a href="/propiedades/1" class="block p-4 hover:bg-signal-yellow transition-colors">
                <div class="font-mono font-bold">Casa Zapopan</div>
                <div class="text-sm text-concrete-500">Av. Vallarta 1234, Jal.</div>
              </a>
              <a href="/propiedades/2" class="block p-4 hover:bg-signal-yellow transition-colors">
                <div class="font-mono font-bold">Depto CDMX</div>
                <div class="text-sm text-concrete-500">Roma Norte, CDMX</div>
              </a>
              <a href="/propiedades/3" class="block p-4 hover:bg-signal-yellow transition-colors">
                <div class="font-mono font-bold">Terreno GDL</div>
                <div class="text-sm text-concrete-500">Zapopan, Jal.</div>
              </a>
            </div>
            <a href="/propiedades" class="block p-4 text-center font-mono text-sm underline hover:bg-concrete-100">
              VER TODAS →
            </a>
          </div>
        </div>
      </div>
    </main>
  </div>

</body>
</html>