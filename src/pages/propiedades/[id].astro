---
import Layout from '../../layouts/Layout.astro';
import { extractDocumentData, inferCategoria, inferProveedor } from '../../lib/document-ai';

const { id } = Astro.params;
const user = Astro.locals.user!;
const pb = Astro.locals.pb;

const CATEGORIAS: Record<string, { label: string; emoji: string }> = {
  predial: { label: 'Predial', emoji: '🏛️' },
  cfe: { label: 'Luz', emoji: '⚡' },
  agua: { label: 'Agua', emoji: '💧' },
  gas: { label: 'Gas', emoji: '🔥' },
  internet: { label: 'Internet', emoji: '🌐' },
  telefono: { label: 'Teléfono', emoji: '📞' },
  condominio: { label: 'Condominio', emoji: '🏢' },
  seguro: { label: 'Seguro', emoji: '🛡️' },
  hipoteca: { label: 'Hipoteca', emoji: '🏦' },
  otro: { label: 'Otro', emoji: '📄' },
};

const PERIODICIDADES: Record<string, { label: string; months: number | null }> = {
  unico: { label: 'Único / no recurrente', months: null },
  mensual: { label: 'Mensual', months: 1 },
  bimestral: { label: 'Bimestral', months: 2 },
  trimestral: { label: 'Trimestral', months: 3 },
  semestral: { label: 'Semestral', months: 6 },
  anual: { label: 'Anual', months: 12 },
};


function addMonths(dateStr: string, months: number) {
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return '';
  const day = d.getDate();
  const result = new Date(d);
  result.setMonth(result.getMonth() + months);
  if (result.getDate() < day) result.setDate(0);
  return result.toISOString().slice(0, 10);
}

function formatMoney(n: number) {
  return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', minimumFractionDigits: 0 }).format(n || 0);
}
function formatDate(d: string) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
}
function categoriaLabel(cat: string) {
  return CATEGORIAS[cat]?.label || 'Otro';
}
function categoriaEmoji(cat: string) {
  return CATEGORIAS[cat]?.emoji || '📄';
}

let propiedad: any = null;
let documentos: any[] = [];
let pagos: any[] = [];
let error = '';
let success = '';

try {
  propiedad = await pb.collection('propiedades').getOne(id!);
  if (propiedad.propietario !== user.id) return Astro.redirect('/propiedades');
} catch {
  return Astro.redirect('/propiedades');
}

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = fd.get('action')?.toString();

    if (action === 'subir_recibo') {
      const archivo = fd.get('archivo');
      if (!(archivo instanceof File) || archivo.size === 0) {
        throw new Error('Debes subir un PDF o imagen del recibo');
      }

      const filename = archivo.name || 'recibo';

      // 1) Valores manuales / heurísticos iniciales
      const categoriaManual = fd.get('categoria')?.toString() || '';
      const proveedorManual = fd.get('proveedor')?.toString().trim() || '';
      const referenciaManual = fd.get('referencia')?.toString().trim() || '';
      const montoManual = parseFloat(fd.get('monto')?.toString() || '0') || 0;
      const fechaPagoManual = fd.get('fecha_pago')?.toString() || '';
      const periodicidadManual = fd.get('periodicidad')?.toString() || 'unico';
      const notas = fd.get('notas')?.toString().trim() || null;

      const categoriaInicial = categoriaManual || inferCategoria(filename);
      const proveedorInicial = proveedorManual || inferProveedor(filename) || '';

      // 2) Crear documento primero para obtener URL pública del archivo
      const createFd = new FormData();
      createFd.append('titulo', `${categoriaLabel(categoriaInicial)} · ${filename}`);
      createFd.append('archivo', archivo);
      createFd.append('categoria', categoriaInicial);
      if (proveedorInicial) createFd.append('proveedor', proveedorInicial);
      if (referenciaManual) createFd.append('referencia', referenciaManual);
      if (montoManual > 0) createFd.append('monto', String(montoManual));
      if (fechaPagoManual) createFd.append('fecha_pago', fechaPagoManual);
      createFd.append('periodicidad', periodicidadManual);
      createFd.append('texto_extraido', [
        `archivo: ${filename}`,
        `mime: ${archivo.type || 'desconocido'}`,
        `categoria_inicial: ${categoriaInicial}`,
        proveedorInicial ? `proveedor_inicial: ${proveedorInicial}` : '',
      ].filter(Boolean).join('\n'));
      createFd.append('extraido_auto', 'false');
      if (notas) createFd.append('notas', notas);
      createFd.append('propiedad', id!);
      createFd.append('usuario', user.id);

      const doc = await pb.collection('documentos_pagos').create(createFd);
      const fileUrl = pb.files.getURL(doc, doc.archivo);

      // 3) Intentar extracción con IA / OCR opcional
      const extracted = await extractDocumentData({
        fileUrl,
        fileName: filename,
        mimeType: archivo.type || '',
        propertyName: propiedad.nombre,
        city: propiedad.ciudad,
        state: propiedad.estado,
      });

      // 4) Resolver valores finales (manual manda sobre IA; IA sobre heurística)
      const categoria = categoriaManual || extracted.categoria || categoriaInicial;
      const proveedor = proveedorManual || extracted.proveedor || proveedorInicial || null;
      const referencia = referenciaManual || extracted.referencia || null;
      const monto = montoManual > 0 ? montoManual : (extracted.monto || 0);
      const fechaPago = fechaPagoManual || extracted.fecha_pago || new Date().toISOString().slice(0, 10);
      const periodicidad = periodicidadManual !== 'unico'
        ? periodicidadManual
        : (extracted.periodicidad || periodicidadManual);
      const proximoPago = PERIODICIDADES[periodicidad]?.months ? addMonths(fechaPago, PERIODICIDADES[periodicidad].months!) : '';

      // 5) Actualizar documento con datos extraídos/finales
      await pb.collection('documentos_pagos').update(doc.id, {
        titulo: `${categoriaLabel(categoria)} · ${filename}`,
        categoria,
        proveedor,
        referencia,
        monto: monto > 0 ? monto : null,
        fecha_pago: fechaPago || null,
        periodicidad,
        proximo_pago: proximoPago || null,
        texto_extraido: extracted.texto_extraido || doc.texto_extraido,
        extraido_auto: extracted.metodo !== 'heuristic',
        notas,
      });

      // 6) Programar siguiente pago si aplica
      let pagoCreado = false;
      if (periodicidad !== 'unico' && proximoPago && monto > 0) {
        const concepto = `${categoriaLabel(categoria)}${proveedor ? ` - ${proveedor}` : ''}`;
        const dup = await pb.collection('pagos').getList(1, 1, {
          filter: `propiedad = "${id}" && usuario = "${user.id}" && concepto = "${concepto}" && fecha_vencimiento = "${proximoPago}" && estatus != "pagado"`,
        }).catch(() => ({ items: [] as any[] }));

        if (!dup.items.length) {
          await pb.collection('pagos').create({
            concepto,
            monto,
            fecha_vencimiento: proximoPago,
            propiedad: id,
            usuario: user.id,
            estatus: 'pendiente',
            linea_captura: referencia || null,
          });
          pagoCreado = true;
        }
      }

      success = extracted.metodo && extracted.metodo !== 'heuristic'
        ? (pagoCreado
            ? 'Recibo analizado con IA y próximo pago programado automáticamente'
            : 'Recibo analizado con IA y guardado correctamente')
        : (pagoCreado
            ? 'Recibo guardado y próximo pago programado automáticamente'
            : 'Recibo guardado correctamente');
    } else if (action === 'eliminar_documento') {
      const docId = fd.get('id')?.toString();
      if (docId) {
        await pb.collection('documentos_pagos').delete(docId);
        success = 'Documento eliminado';
      }
    }
  } catch (e: any) {
    error = e?.message || 'Error al procesar la solicitud';
  }
}

try {
  const dResult = await pb.collection('documentos_pagos').getList(1, 100, {
    filter: `propiedad = "${id}" && usuario = "${user.id}"`,
  });
  documentos = dResult.items.sort((a: any, b: any) => new Date(b.created || 0).getTime() - new Date(a.created || 0).getTime());
} catch (e: any) {
  error = error || `No se pudieron cargar los recibos: ${e?.message || e}`;
}

try {
  const pResult = await pb.collection('pagos').getList(1, 20, {
    filter: `propiedad = "${id}" && usuario = "${user.id}" && estatus != "pagado"`,
    sort: 'fecha_vencimiento',
  });
  pagos = pResult.items;
} catch {}

const initials = user.name
  ? user.name.split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2)
  : user.email[0].toUpperCase();

const recurrentes = documentos.filter(d => d.periodicidad && d.periodicidad !== 'unico');

function monthsFor(periodicidad: string): number | null {
  return PERIODICIDADES[periodicidad]?.months ?? null;
}

const hoy = new Date();
const limiteCalendario = new Date(hoy);
limiteCalendario.setFullYear(limiteCalendario.getFullYear() + 1);

const projectedPagos: any[] = [];
for (const doc of recurrentes) {
  const months = monthsFor(doc.periodicidad);
  if (!months || !doc.proximo_pago) continue;

  let current = new Date(doc.proximo_pago);
  if (isNaN(current.getTime())) continue;

  while (current <= limiteCalendario) {
    const fecha = current.toISOString().slice(0, 10);
    const concepto = `${categoriaLabel(doc.categoria)}${doc.proveedor ? ` - ${doc.proveedor}` : ''}`;
    const existsReal = pagos.some((p: any) =>
      p.concepto === concepto &&
      p.fecha_vencimiento && p.fecha_vencimiento.slice(0, 10) === fecha
    );

    if (!existsReal) {
      projectedPagos.push({
        concepto,
        fecha_vencimiento: fecha,
        monto: doc.monto || 0,
        linea_captura: doc.referencia || '',
        projected: true,
      });
    }

    const next = new Date(current);
    next.setMonth(next.getMonth() + months);
    current = next;
  }
}

projectedPagos.sort((a, b) => new Date(a.fecha_vencimiento).getTime() - new Date(b.fecha_vencimiento).getTime());
---

<Layout title={`${propiedad.nombre} - Propiedades Premier`}>
<div class="flex flex-col min-h-screen">
  <header class="bg-black text-white border-b-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/" class="w-10 h-10 bg-signal-yellow flex items-center justify-center flex-shrink-0">
          <span class="text-black font-mono font-bold">PP</span>
        </a>
        <span class="font-mono font-bold text-lg hidden sm:block">PROPIEDADES PREMIER</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="font-mono text-sm hidden sm:block">{user.email}</span>
        <div class="w-10 h-10 bg-concrete-700 border-2 border-white flex items-center justify-center">
          <span class="font-mono font-bold">{initials}</span>
        </div>
      </div>
    </div>
  </header>

  <div class="flex flex-1">
    <aside class="w-64 bg-concrete-900 text-white border-r-4 border-black hidden lg:block">
      <nav class="p-4">
        <div class="mb-6"><span class="font-mono text-xs text-concrete-400">MENÚ PRINCIPAL</span></div>
        <ul class="space-y-1">
          <li><a href="/dashboard" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">DASHBOARD</a></li>
          <li><a href="/propiedades" class="flex items-center gap-3 px-4 py-3 bg-signal-yellow text-black font-mono font-medium">MIS PROPIEDADES</a></li>
          <li><a href="/pagos" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">PAGOS</a></li>
          <li><a href="/alertas" class="flex items-center gap-3 px-4 py-3 hover:bg-concrete-800 font-mono text-sm transition-colors">ALERTAS</a></li>
        </ul>
        <div class="mt-8 mb-6"><span class="font-mono text-xs text-concrete-400">CUENTA</span></div>
        <ul><li><a href="/api/auth/signout" class="flex items-center gap-3 px-4 py-3 hover:bg-red-900 font-mono text-sm transition-colors">CERRAR SESIÓN</a></li></ul>
      </nav>
    </aside>

    <main class="flex-1 p-4 md:p-6 pb-24 lg:pb-6 overflow-x-hidden">
      <div class="max-w-5xl mx-auto">
        <a href="/propiedades" class="inline-flex items-center gap-2 font-mono text-sm text-concrete-500 hover:text-black mb-6 group">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          MIS PROPIEDADES
        </a>

        <div class="bg-white border-4 border-black mb-8">
          <div class="p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <span class="px-2 py-0.5 bg-concrete-200 font-mono text-xs font-bold uppercase">{propiedad.tipo || 'propiedad'}</span>
                <span class={`w-2.5 h-2.5 rounded-full ${propiedad.estatus === 'activa' ? 'bg-green-500' : 'bg-concrete-400'}`}></span>
              </div>
              <h1 class="font-mono font-bold text-2xl md:text-3xl mb-1">{propiedad.nombre}</h1>
              <p class="text-concrete-600">{propiedad.direccion}</p>
              {(propiedad.ciudad || propiedad.estado) && (
                <p class="text-concrete-500 text-sm">{[propiedad.ciudad, propiedad.estado].filter(Boolean).join(', ')}</p>
              )}
            </div>
            <div class="flex gap-3 flex-shrink-0">
              <a href={`/pagos?propiedad=${propiedad.id}`} class="px-5 py-2 bg-black text-white font-mono text-sm font-bold border-2 border-black hover:bg-signal-yellow hover:text-black transition-colors">VER PAGOS</a>
              <form method="POST" onsubmit="return confirm('¿Eliminar esta propiedad?')" action="/propiedades">
                <input type="hidden" name="action" value="eliminar" />
                <input type="hidden" name="id" value={propiedad.id} />
                <button type="submit" class="px-4 py-2 border-2 border-red-300 text-red-600 font-mono text-sm hover:bg-red-50 transition-colors">ELIMINAR</button>
              </form>
            </div>
          </div>
          <div class="border-t-4 border-black grid grid-cols-3 divide-x-4 divide-black">
            <div class="p-4 text-center">
              <div class="font-mono font-bold text-2xl">{documentos.length}</div>
              <div class="font-mono text-xs text-concrete-500">RECIBOS</div>
            </div>
            <div class="p-4 text-center">
              <div class="font-mono font-bold text-2xl">{recurrentes.length}</div>
              <div class="font-mono text-xs text-concrete-500">RECURRENTES</div>
            </div>
            <div class="p-4 text-center">
              <div class={`font-mono font-bold text-2xl ${pagos.length > 0 ? 'text-red-600' : 'text-green-600'}`}>{pagos.length}</div>
              <div class="font-mono text-xs text-concrete-500">PAGOS PENDIENTES</div>
            </div>
          </div>
        </div>

        {error && <div class="bg-red-100 border-4 border-red-500 p-4 mb-6"><p class="font-mono text-sm text-red-700">{error}</p></div>}
        {success && <div class="bg-green-100 border-4 border-green-500 p-4 mb-6"><p class="font-mono text-sm text-green-700">✓ {success}</p></div>}

        <!-- Upload box -->
        <section class="mb-8">
          <div class="bg-signal-yellow border-4 border-black p-6 md:p-8">
            <div class="flex items-start justify-between gap-4 mb-6">
              <div>
                <h2 class="font-mono font-bold text-2xl mb-2">SUBE UN RECIBO</h2>
                <p class="text-black/70">Sube un PDF, foto o imagen. El sistema intentará clasificarlo y, si aplica, programará el siguiente pago.</p>
              </div>
              <div class="text-4xl">📂</div>
            </div>

            <form method="POST" enctype="multipart/form-data" class="space-y-5" id="recibo-form">
              <input type="hidden" name="action" value="subir_recibo" />

              <!-- Carga rápida -->
              <div class="bg-white border-4 border-black p-5">
                <label class="block font-mono text-sm font-bold mb-3">ARCHIVO (PDF o imagen)</label>
                <input
                  type="file"
                  name="archivo"
                  accept="application/pdf,image/*"
                  required
                  class="w-full px-4 py-4 bg-concrete-50 border-2 border-black font-mono text-sm"
                />
                <div class="flex flex-wrap items-center gap-3 mt-4">
                  <button type="submit" class="px-8 py-4 bg-black text-white font-mono font-bold border-4 border-black hover:bg-white hover:text-black transition-colors">
                    SUBIR RECIBO →
                  </button>
                  <span class="font-mono text-xs text-black/60">Puedes subir primero y corregir después.</span>
                </div>
              </div>

              <!-- Ajustes manuales colapsados -->
              <details class="bg-white border-4 border-black group">
                <summary class="cursor-pointer list-none p-5 flex items-center justify-between gap-4">
                  <div>
                    <div class="font-mono font-bold text-lg">AJUSTAR DATOS MANUALMENTE</div>
                    <div class="font-mono text-xs text-concrete-500">Opcional. Úsalo solo si quieres ayudar al sistema o corregir algo.</div>
                  </div>
                  <span class="font-mono text-2xl group-open:rotate-45 transition-transform">+</span>
                </summary>

                <div class="px-5 pb-5 border-t-2 border-concrete-200 grid md:grid-cols-2 gap-4">
                  <div>
                    <label class="block font-mono text-sm font-bold mb-2 mt-4">CATEGORÍA</label>
                    <select name="categoria" class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none">
                      <option value="">Auto-detectar por nombre del archivo</option>
                      {Object.entries(CATEGORIAS).map(([key, c]) => <option value={key}>{c.emoji} {c.label}</option>)}
                    </select>
                  </div>

                  <div>
                    <label class="block font-mono text-sm font-bold mb-2 mt-4">PERIODICIDAD</label>
                    <select name="periodicidad" class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none">
                      {Object.entries(PERIODICIDADES).map(([key, p]) => <option value={key}>{p.label}</option>)}
                    </select>
                  </div>

                  <div>
                    <label class="block font-mono text-sm font-bold mb-2">PROVEEDOR</label>
                    <input type="text" name="proveedor" placeholder="CFE, SACMEX, Telmex..." class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none" />
                  </div>

                  <div>
                    <label class="block font-mono text-sm font-bold mb-2">REFERENCIA / CONTRATO</label>
                    <input type="text" name="referencia" placeholder="Número de servicio o referencia" class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none" />
                  </div>

                  <div>
                    <label class="block font-mono text-sm font-bold mb-2">MONTO</label>
                    <input type="number" name="monto" step="0.01" min="0" placeholder="2450.00" class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none" />
                    <p class="font-mono text-xs text-concrete-500 mt-1">Si lo capturas, mejora la programación del siguiente pago.</p>
                  </div>

                  <div>
                    <label class="block font-mono text-sm font-bold mb-2">FECHA DE PAGO</label>
                    <input type="date" name="fecha_pago" value={new Date().toISOString().slice(0,10)} class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none" />
                  </div>

                  <div class="md:col-span-2">
                    <label class="block font-mono text-sm font-bold mb-2">NOTAS</label>
                    <input type="text" name="notas" placeholder="Ej: se pagó con descuento anual, incluye recargos, etc." class="w-full px-4 py-3 bg-concrete-50 border-2 border-black font-mono text-sm focus:outline-none" />
                  </div>
                </div>
              </details>
            </form>
          </div>
        </section>

        <!-- Vault table -->
        <section class="mb-8">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-mono font-bold text-xl">BÓVEDA DE RECIBOS</h2>
            <span class="font-mono text-sm text-concrete-500">{documentos.length} documento{documentos.length !== 1 ? 's' : ''}</span>
          </div>

          {documentos.length > 0 ? (
            <div class="bg-white border-4 border-black overflow-x-auto">
              <table class="w-full min-w-[900px]">
                <thead class="bg-black text-white font-mono text-xs">
                  <tr>
                    <th class="text-left p-3">TIPO</th>
                    <th class="text-left p-3">IA</th>
                    <th class="text-left p-3">ARCHIVO</th>
                    <th class="text-left p-3">PROVEEDOR</th>
                    <th class="text-left p-3">MONTO</th>
                    <th class="text-left p-3">PAGADO</th>
                    <th class="text-left p-3">RECURRENCIA</th>
                    <th class="text-left p-3">PRÓXIMO</th>
                    <th class="text-left p-3">ACCIONES</th>
                  </tr>
                </thead>
                <tbody class="divide-y-2 divide-concrete-200">
                  {documentos.map((doc: any) => {
                    const fileUrl = doc.archivo ? pb.files.getURL(doc, doc.archivo) : '';
                    return (
                      <tr class="font-mono text-sm hover:bg-concrete-50">
                        <td class="p-3 whitespace-nowrap">{categoriaEmoji(doc.categoria)} {categoriaLabel(doc.categoria).toUpperCase()}</td>
                        <td class="p-3">
                          {doc.extraido_auto ? (
                            <span class="inline-block px-2 py-1 bg-green-100 text-green-700 border border-green-300 text-xs font-bold">IA ✓</span>
                          ) : (
                            <span class="inline-block px-2 py-1 bg-concrete-100 text-concrete-500 border border-concrete-300 text-xs font-bold">BASE</span>
                          )}
                        </td>
                        <td class="p-3">
                          <a href={fileUrl} target="_blank" rel="noopener" class="underline hover:no-underline break-all">{doc.archivo}</a>
                        </td>
                        <td class="p-3">{doc.proveedor || '—'}</td>
                        <td class="p-3">{doc.monto ? formatMoney(doc.monto) : '—'}</td>
                        <td class="p-3">{formatDate(doc.fecha_pago)}</td>
                        <td class="p-3">{PERIODICIDADES[doc.periodicidad]?.label || '—'}</td>
                        <td class="p-3">{formatDate(doc.proximo_pago)}</td>
                        <td class="p-3">
                          <div class="flex gap-3 items-center">
                            {doc.referencia && <button type="button" class="copy-ref text-xs underline" data-ref={doc.referencia}>COPIAR REF</button>}
                            <form method="POST" onsubmit="return confirm('¿Eliminar este documento?')" class="inline">
                              <input type="hidden" name="action" value="eliminar_documento" />
                              <input type="hidden" name="id" value={doc.id} />
                              <button type="submit" class="text-xs text-red-600 underline">ELIMINAR</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="bg-concrete-100 border-4 border-concrete-300 p-10 text-center">
              <div class="text-4xl mb-3">🧾</div>
              <h3 class="font-mono font-bold text-xl mb-2">SIN RECIBOS</h3>
              <p class="text-concrete-500">Sube tu primer recibo para crear la bóveda documental de esta propiedad.</p>
            </div>
          )}
        </section>

        <!-- Scheduled payments -->
        <section>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="font-mono font-bold text-xl">PAGOS PROGRAMADOS / PENDIENTES</h2>
              <p class="font-mono text-xs text-concrete-500 mt-1">Mostramos pagos reales y también calendario proyectado a 12 meses desde tus recibos recurrentes.</p>
            </div>
            <a href={`/pagos?propiedad=${propiedad.id}`} class="font-mono text-sm underline hover:no-underline">VER TODOS →</a>
          </div>

          {(pagos.length > 0 || projectedPagos.length > 0) ? (
            <div class="space-y-4">
              {pagos.length > 0 && (
                <div>
                  <div class="font-mono text-xs font-bold text-concrete-500 mb-2">PAGOS REALES PENDIENTES</div>
                  <div class="bg-white border-4 border-black divide-y-2 divide-concrete-200">
                    {pagos.map((p: any) => (
                      <div class="p-4 flex items-center justify-between gap-4 hover:bg-concrete-50">
                        <div>
                          <div class="font-mono font-bold">{p.concepto}</div>
                          <div class="font-mono text-xs text-concrete-500">Vence: {formatDate(p.fecha_vencimiento)}{p.linea_captura ? ` · Ref: ${p.linea_captura}` : ''}</div>
                        </div>
                        <div class="font-mono font-bold">{formatMoney(p.monto)}</div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {projectedPagos.length > 0 && (
                <div>
                  <div class="font-mono text-xs font-bold text-concrete-500 mb-2">CALENDARIO PROYECTADO (12 MESES)</div>
                  <div class="bg-white border-4 border-concrete-300 divide-y-2 divide-concrete-100">
                    {projectedPagos.map((p: any) => (
                      <div class="p-4 flex items-center justify-between gap-4 hover:bg-concrete-50">
                        <div>
                          <div class="font-mono font-bold text-concrete-700">{p.concepto}</div>
                          <div class="font-mono text-xs text-concrete-500">Estimado para: {formatDate(p.fecha_vencimiento)}{p.linea_captura ? ` · Ref: ${p.linea_captura}` : ''}</div>
                        </div>
                        <div class="text-right">
                          <div class="font-mono font-bold text-concrete-700">{p.monto ? formatMoney(p.monto) : 'MONTO PENDIENTE'}</div>
                          <div class="font-mono text-[10px] text-concrete-400">PROYECCIÓN</div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ) : (
            <div class="bg-concrete-100 border-4 border-concrete-300 p-6 text-center">
              <p class="font-mono text-concrete-500">Aún no hay pagos programados ni recibos recurrentes con próxima fecha.</p>
            </div>
          )}
        </section>
      </div>
    </main>
  </div>

  <nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-black text-white border-t-4 border-signal-yellow flex justify-around py-3">
    <a href="/dashboard" class="flex flex-col items-center"><span class="font-mono text-xs mt-0.5">INICIO</span></a>
    <a href="/propiedades" class="flex flex-col items-center text-signal-yellow"><span class="font-mono text-xs mt-0.5">PROPS</span></a>
    <a href="/pagos" class="flex flex-col items-center"><span class="font-mono text-xs mt-0.5">PAGOS</span></a>
    <a href="/alertas" class="flex flex-col items-center"><span class="font-mono text-xs mt-0.5">ALERTAS</span></a>
  </nav>
</div>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.copy-ref') as HTMLButtonElement | null;
    if (!btn) return;
    const ref = btn.dataset.ref || '';
    navigator.clipboard.writeText(ref).then(() => {
      const orig = btn.textContent;
      btn.textContent = '¡COPIADO!';
      setTimeout(() => { btn.textContent = orig || 'COPIAR REF'; }, 2000);
    });
  });
</script>
</Layout>
