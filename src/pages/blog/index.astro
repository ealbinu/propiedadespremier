---
import Layout from '../../layouts/Layout.astro';
import { createPocketBase } from '../../lib/pocketbase';

const pb = createPocketBase();

let posts: any[] = [];
let categories: any[] = [];
try {
  const result = await pb.collection('blog_posts').getList(1, 12, {
    filter: 'publicado = true',
    sort: '-fecha_publicacion',
    expand: 'categoria',
  });
  posts = result.items;

  const catResult = await pb.collection('categorias_blog').getFullList({ sort: 'nombre' });
  categories = catResult;
} catch (e) {
  // Collections may be empty
}

const selectedCategory = Astro.url.searchParams.get('categoria') || '';

const filteredPosts = selectedCategory
  ? posts.filter(p => p.expand?.categoria?.slug === selectedCategory)
  : posts;

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
}

function getImageUrl(post: any) {
  if (post.imagen) {
    return pb.files.getURL(post, post.imagen);
  }
  return '';
}

const user = Astro.locals.user;
---

<Layout title="Blog - Propiedades Premier">
  <!-- Header -->
  <header class="bg-black text-white border-b-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
          <span class="text-black font-mono font-bold">PP</span>
        </div>
        <span class="font-mono font-bold text-lg hidden sm:block">PROPIEDADES PREMIER</span>
      </a>
      <nav class="flex items-center gap-1">
        <a href="/blog" class="px-4 py-2 font-mono text-sm font-medium bg-signal-yellow text-black">BLOG</a>
        {user ? (
          <a href="/dashboard" class="px-4 py-2 font-mono text-sm font-medium border-2 border-white hover:bg-white hover:text-black transition-colors">DASHBOARD</a>
        ) : (
          <a href="/signin" class="px-4 py-2 font-mono text-sm font-medium border-2 border-white hover:bg-white hover:text-black transition-colors">ENTRAR</a>
        )}
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="bg-concrete-200 border-b-4 border-black">
    <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <div class="inline-block bg-black text-white px-3 py-1 font-mono text-sm mb-6">
          RECURSOS Y GUÍAS
        </div>
        <h1 class="font-mono font-bold text-5xl md:text-6xl leading-none mb-6">
          BLOG
        </h1>
        <p class="text-xl text-concrete-700 max-w-2xl">
          Tips, guías y recursos sobre gestión inmobiliaria en México. Todo lo que necesitas saber para administrar tus propiedades.
        </p>
      </div>
    </div>
  </section>

  <!-- Categories -->
  {categories.length > 0 && (
    <section class="bg-white border-b-4 border-black">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex flex-wrap gap-2">
          <a href="/blog" class={`px-4 py-2 font-mono text-sm font-medium border-2 border-black transition-colors ${!selectedCategory ? 'bg-black text-white' : 'hover:bg-signal-yellow'}`}>
            TODOS
          </a>
          {categories.map((cat: any) => (
            <a href={`/blog?categoria=${cat.slug}`} class={`px-4 py-2 font-mono text-sm font-medium border-2 border-black transition-colors ${selectedCategory === cat.slug ? 'bg-black text-white' : 'hover:bg-signal-yellow'}`}>
              {cat.nombre.toUpperCase()}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Blog Grid -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-6">
      {filteredPosts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {filteredPosts.map((post: any) => (
            <article class="bg-white border-4 border-black hover:translate-y-[-4px] transition-transform">
              <div class="aspect-video bg-concrete-300 border-b-4 border-black flex items-center justify-center overflow-hidden">
                {getImageUrl(post) ? (
                  <img src={getImageUrl(post)} alt={post.titulo} class="w-full h-full object-cover" />
                ) : (
                  <div class="text-concrete-500 font-mono text-sm">[IMAGEN]</div>
                )}
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                  {post.expand?.categoria && (
                    <span class="px-2 py-1 bg-signal-yellow font-mono text-xs font-bold">{post.expand.categoria.nombre.toUpperCase()}</span>
                  )}
                  <span class="text-concrete-500 font-mono text-xs">{formatDate(post.fecha_publicacion)}</span>
                </div>
                <h2 class="font-mono font-bold text-xl mb-3 leading-tight hover:underline">
                  <a href={`/blog/${post.slug}`}>{post.titulo}</a>
                </h2>
                <p class="text-concrete-600 mb-4 text-sm">{post.extracto}</p>
                <div class="flex items-center justify-between pt-4 border-t-2 border-concrete-200">
                  {post.tiempo_lectura && (
                    <span class="text-concrete-500 font-mono text-xs">{post.tiempo_lectura} min de lectura</span>
                  )}
                  <a href={`/blog/${post.slug}`} class="font-mono text-sm font-bold underline hover:no-underline">
                    LEER →
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <div class="inline-block bg-concrete-200 border-4 border-black p-12">
            <h2 class="font-mono font-bold text-2xl mb-4">NO HAY ARTÍCULOS AÚN</h2>
            <p class="text-concrete-600">Pronto publicaremos contenido sobre gestión inmobiliaria.</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-black text-white py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h3 class="font-mono font-bold text-3xl mb-4">
        SUSCRÍBETE AL <span class="text-signal-yellow">NEWSLETTER</span>
      </h3>
      <p class="text-concrete-300 mb-8">
        Recibe las últimas guías y tips directamente en tu correo. Sin spam.
      </p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input
          type="email"
          placeholder="tu@email.com"
          class="flex-1 px-4 py-3 bg-concrete-800 border-2 border-concrete-600 font-mono text-sm focus:outline-none focus:border-signal-yellow"
        >
        <button class="px-6 py-3 bg-signal-yellow text-black font-mono font-bold border-2 border-signal-yellow hover:bg-white transition-colors">
          SUSCRIBIRME
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-concrete-900 text-white py-12 border-t-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
            <span class="text-black font-mono font-bold">PP</span>
          </div>
          <span class="font-mono font-bold">PROPIEDADES PREMIER</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-6 text-sm">
          <a href="/" class="hover:text-signal-yellow">Inicio</a>
          <a href="/blog" class="hover:text-signal-yellow">Blog</a>
          <a href="/signin" class="hover:text-signal-yellow">Entrar</a>
          <a href="/signup" class="hover:text-signal-yellow">Crear cuenta</a>
        </nav>
        <p class="text-concrete-500 text-sm">&copy; 2026 Propiedades Premier</p>
      </div>
    </div>
  </footer>
</Layout>
