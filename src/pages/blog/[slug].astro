---
import Layout from '../../layouts/Layout.astro';
import { createPocketBase } from '../../lib/pocketbase';

const { slug } = Astro.params;
const pb = createPocketBase();

let post: any = null;
let relatedPosts: any[] = [];

try {
  const result = await pb.collection('blog_posts').getList(1, 1, {
    filter: `slug = "${slug}" && publicado = true`,
    expand: 'categoria',
  });

  if (result.items.length === 0) {
    return Astro.redirect('/blog');
  }

  post = result.items[0];

  // Fetch related posts (same category, different post)
  if (post.categoria) {
    const related = await pb.collection('blog_posts').getList(1, 3, {
      filter: `categoria = "${post.categoria}" && id != "${post.id}" && publicado = true`,
      sort: '-fecha_publicacion',
      expand: 'categoria',
    });
    relatedPosts = related.items;
  }
} catch {
  return Astro.redirect('/blog');
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' }).toUpperCase();
}

function getImageUrl(record: any, field: string) {
  if (record[field]) {
    return pb.files.getURL(record, record[field]);
  }
  return '';
}

const user = Astro.locals.user;
---

<Layout title={`${post.titulo} - Propiedades Premier`}>
  <!-- Header -->
  <header class="bg-black text-white border-b-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
          <span class="text-black font-mono font-bold">PP</span>
        </div>
        <span class="font-mono font-bold text-lg hidden sm:block">PROPIEDADES PREMIER</span>
      </a>
      <nav class="flex items-center gap-1">
        <a href="/blog" class="px-4 py-2 font-mono text-sm font-medium bg-signal-yellow text-black">BLOG</a>
        {user ? (
          <a href="/dashboard" class="px-4 py-2 font-mono text-sm font-medium border-2 border-white hover:bg-white hover:text-black transition-colors">DASHBOARD</a>
        ) : (
          <a href="/signin" class="px-4 py-2 font-mono text-sm font-medium border-2 border-white hover:bg-white hover:text-black transition-colors">ENTRAR</a>
        )}
      </nav>
    </div>
  </header>

  <!-- Article Header -->
  <section class="bg-concrete-200 border-b-4 border-black">
    <div class="max-w-4xl mx-auto px-6 py-16">
      <a href="/blog" class="inline-block font-mono text-sm mb-6 underline hover:no-underline">&larr; VOLVER AL BLOG</a>
      <div class="flex items-center gap-4 mb-6">
        {post.expand?.categoria && (
          <span class="px-3 py-1 bg-signal-yellow font-mono text-sm font-bold border-2 border-black">{post.expand.categoria.nombre.toUpperCase()}</span>
        )}
        <span class="font-mono text-sm text-concrete-600">{formatDate(post.fecha_publicacion)}</span>
      </div>
      <h1 class="font-mono font-bold text-4xl md:text-5xl leading-tight mb-6">
        {post.titulo}
      </h1>
      <div class="flex items-center gap-4 text-sm text-concrete-600">
        {post.autor && <span>Por {post.autor}</span>}
        {post.autor && post.tiempo_lectura && <span>&bull;</span>}
        {post.tiempo_lectura && <span>{post.tiempo_lectura} min de lectura</span>}
      </div>
    </div>
  </section>

  <!-- Featured Image -->
  {getImageUrl(post, 'imagen') && (
    <div class="max-w-4xl mx-auto px-6 -mt-8">
      <div class="aspect-video border-4 border-black overflow-hidden">
        <img src={getImageUrl(post, 'imagen')} alt={post.titulo} class="w-full h-full object-cover" />
      </div>
    </div>
  )}

  <!-- Article Content -->
  <article class="max-w-4xl mx-auto px-6 py-12">
    <div class="prose prose-lg max-w-none">
      <Fragment set:html={post.contenido} />
    </div>

    <!-- Share -->
    <div class="mt-12 pt-8 border-t-4 border-black">
      <h3 class="font-mono font-bold mb-4">COMPARTIR</h3>
      <div class="flex gap-3">
        <button onclick={`window.open('https://twitter.com/intent/tweet?url=' + encodeURIComponent(window.location.href) + '&text=' + encodeURIComponent('${post.titulo}'), '_blank')`} class="px-4 py-2 bg-black text-white font-mono text-sm border-2 border-black hover:bg-signal-yellow hover:text-black transition-colors">
          TWITTER
        </button>
        <button onclick={`window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(window.location.href), '_blank')`} class="px-4 py-2 bg-black text-white font-mono text-sm border-2 border-black hover:bg-signal-yellow hover:text-black transition-colors">
          FACEBOOK
        </button>
        <button onclick={`window.open('https://wa.me/?text=' + encodeURIComponent('${post.titulo} ' + window.location.href), '_blank')`} class="px-4 py-2 bg-black text-white font-mono text-sm border-2 border-black hover:bg-signal-yellow hover:text-black transition-colors">
          WHATSAPP
        </button>
        <button onclick="navigator.clipboard.writeText(window.location.href); this.textContent='COPIADO!'; setTimeout(() => this.textContent='COPIAR LINK', 2000)" class="px-4 py-2 bg-black text-white font-mono text-sm border-2 border-black hover:bg-signal-yellow hover:text-black transition-colors">
          COPIAR LINK
        </button>
      </div>
    </div>
  </article>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="bg-concrete-200 border-t-4 border-black py-16">
      <div class="max-w-7xl mx-auto px-6">
        <h3 class="font-mono font-bold text-2xl mb-8">ARTÍCULOS RELACIONADOS</h3>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedPosts.map((rp: any) => (
            <article class="bg-white border-4 border-black">
              <div class="aspect-video bg-concrete-300 border-b-4 border-black overflow-hidden">
                {getImageUrl(rp, 'imagen') ? (
                  <img src={getImageUrl(rp, 'imagen')} alt={rp.titulo} class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-concrete-200">
                    <svg class="w-16 h-16 text-concrete-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                  </div>
                )}
              </div>
              <div class="p-6">
                {rp.expand?.categoria && (
                  <span class="px-2 py-1 bg-signal-yellow font-mono text-xs font-bold">{rp.expand.categoria.nombre.toUpperCase()}</span>
                )}
                <h4 class="font-mono font-bold mt-3 mb-2 hover:underline">
                  <a href={`/blog/${rp.slug}`}>{rp.titulo}</a>
                </h4>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Footer -->
  <footer class="bg-concrete-900 text-white py-12 border-t-4 border-signal-yellow">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-signal-yellow flex items-center justify-center">
            <span class="text-black font-mono font-bold">PP</span>
          </div>
          <span class="font-mono font-bold">PROPIEDADES PREMIER</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-6 text-sm">
          <a href="/" class="hover:text-signal-yellow">Inicio</a>
          <a href="/blog" class="hover:text-signal-yellow">Blog</a>
          <a href="/signin" class="hover:text-signal-yellow">Entrar</a>
          <a href="/signup" class="hover:text-signal-yellow">Crear cuenta</a>
        </nav>
        <p class="text-concrete-500 text-sm">&copy; 2026 Propiedades Premier</p>
      </div>
    </div>
  </footer>
</Layout>
